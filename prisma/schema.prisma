generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique // Para subdomínios (white-label)
  isActive  Boolean  @default(true)
  
  // Queue Config
  queueOpenTime   String   @default("09:00")
  queueCloseTime  String   @default("18:00")
  isQueuePaused   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users             User[]
  customers         Customer[]
  services          Service[]
  appointments      Appointment[]
  finances          Finance[]
  cashRegisters     CashRegister[]
  inventory         Inventory[]
  loyaltySystems    LoyaltySystem[]
  customerFinances  CustomerFinance[]
  queueItems        QueueManager[]
  campaigns         MarketingCampaigns[]
  reviews           Review[]
  businessHours     BusinessHour[]
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("BARBER") // ADMIN, MANAGER, BARBER, RECEPTIONIST
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  appointments  Appointment[] @relation("BarberAppointments")
  commissions   Finance[]     @relation("BarberCommissions")
  queueItems    QueueManager[] @relation("BarberQueue")
  cashRegisters CashRegister[] @relation("UserCashRegisters")
}

model Customer {
  id            String    @id @default(uuid())
  name          String
  phone         String    @unique
  preferences   String?
  totalVisits   Int       @default(0)
  lastVisit     DateTime?
  notes         String?
  isBlocked     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  appointments  Appointment[]
  loyalty       LoyaltySystem?
  finance       CustomerFinance?
  queueItem     QueueManager?
  reviews       Review[]
}

model Service {
  id              String    @id @default(uuid())
  name            String
  description     String?
  durationMinutes Int
  price           Float
  active          Boolean   @default(true)
  pointsEarned    Int       @default(0) // Pontos que o cliente ganha ao fazer este serviço
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  appointments    Appointment[]
}

model Appointment {
  id          String    @id @default(uuid())
  date        DateTime
  startTime   String
  endTime     String
  status      String    @default("PENDING") 
  
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  
  barberId    String
  barber      User      @relation("BarberAppointments", fields: [barberId], references: [id])
  
  serviceId   String
  service     Service   @relation(fields: [serviceId], references: [id])

  finance     Finance?  
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Finance {
  id               String    @id @default(uuid())
  type             String    // INCOME, EXPENSE
  amount           Float
  description      String
  date             DateTime
  paymentMethod    String    @default("MONEY") // MONEY, PIX, CREDIT_CARD, DEBIT_CARD
  status           String    @default("PAID")  // PAID, PENDING, CANCELLED
  
  appointmentId    String?   @unique
  appointment      Appointment? @relation(fields: [appointmentId], references: [id])
  
  barberId         String?
  barber           User?     @relation("BarberCommissions", fields: [barberId], references: [id])
  barberCommission Float?
  
  cashRegisterId   String?
  cashRegister     CashRegister? @relation(fields: [cashRegisterId], references: [id])
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CashRegister {
  id             String    @id @default(uuid())
  status         String    @default("OPEN") // OPEN, CLOSED
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  initialBalance Float     @default(0)
  finalBalance   Float?
  
  openedById     String
  openedBy       User      @relation("UserCashRegisters", fields: [openedById], references: [id])
  
  finances       Finance[]
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Inventory {
  id          String    @id @default(uuid())
  productName String
  quantity    Int
  minQuantity Int
  price       Float
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// -----------------------------------------
// V2: FIDELIDADE, FINANCEIRO DO CLIENTE E FILA
// -----------------------------------------

model LoyaltySystem {
  id             String    @id @default(uuid())
  points         Int       @default(0)
  vipLevel       String    @default("BRONZE") // BRONZE, SILVER, GOLD, BLACK
  
  customerId     String    @unique
  customer       Customer  @relation(fields: [customerId], references: [id])
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CustomerFinance {
  id             String    @id @default(uuid())
  availableBalance Float   @default(0) // Créditos ou Cashback
  debtBalance    Float     @default(0) // Fiado/Devedor
  
  customerId     String    @unique
  customer       Customer  @relation(fields: [customerId], references: [id])
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model QueueManager {
  id             String    @id @default(uuid())
  position       Int       @default(0)
  status         String    @default("WAITING") // WAITING, IN_PROGRESS, COMPLETED
  estimatedWaitMins Int    @default(0)
  
  customerId     String    @unique
  customer       Customer  @relation(fields: [customerId], references: [id])
  
  barberId       String?
  barber         User?     @relation("BarberQueue", fields: [barberId], references: [id])
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MarketingCampaigns {
  id             String    @id @default(uuid())
  title          String
  message        String
  imageUrl       String?
  status         String    @default("DRAFT") // DRAFT, SENDING, COMPLETED
  sentCount      Int       @default(0)
  targetAudience String    @default("ALL") // ALL, VIP, ABSENT_30_DAYS
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Review {
  id             String    @id @default(uuid())
  rating         Int
  comment        String?
  
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt      DateTime  @default(now())
}

model BusinessHour {
  id          String   @id @default(uuid())
  dayOfWeek   Int      @unique // 0 = Domingo, 1 = Segunda, ..., 6 = Sábado
  isClosed    Boolean  @default(false)
  openTime    String?  // Ex: "09:00"
  closeTime   String?  // Ex: "19:00"
  breakStart  String?  // Ex: "12:00" (Almoço início)
  breakEnd    String?  // Ex: "13:00" (Almoço fim)
  
  tenantId String?
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


